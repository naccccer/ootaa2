Options -Indexes

SetEnv SMSIR_FAKE false
SetEnv SMSIR_API_KEY "xNnZenpVn9ekpLcuScResxeDUCWHpj3eq7KscubLvYiKfjbY"
SetEnv SMSIR_TEMPLATE_ID "440884"

RewriteEngine On

RewriteRule ^(?:src|config|database|scripts|storage)(?:/|$) - [F,L]
RewriteRule ^([0-9]{4})$ index.php?room=$1 [QSA,L]
RewriteRule ^room/([0-9]{4})$ index.php?room=$1 [QSA,L]
RewriteRule ^api/?(.*)$ api.php?route=$1 [QSA,L]
RewriteRule ^file/([A-Za-z0-9]+)$ download.php?id=$1 [QSA,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^$ index.php [L]

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/manifest+json "access plus 1 day"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|woff2|svg|png)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    <FilesMatch "^(index\.php|api\.php|download\.php)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
    </FilesMatch>

    <Files "manifest.webmanifest">
        Header set Cache-Control "public, max-age=86400"
    </Files>

    <Files "sw.js">
        Header set Cache-Control "no-cache, must-revalidate"
    </Files>
</IfModule>
