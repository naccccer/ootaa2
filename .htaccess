Options -Indexes

RewriteEngine On

RewriteRule ^(?:src|config|database|scripts|storage)(?:/|$) - [F,L]
RewriteRule ^([0-9]{4})$ index.php?room=$1 [QSA,L]
RewriteRule ^room/([0-9]{4})$ index.php?room=$1 [QSA,L]
RewriteRule ^api/?(.*)$ api.php?route=$1 [QSA,L]
RewriteRule ^file/([A-Za-z0-9]+)$ download.php?id=$1 [QSA,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^$ index.php [L]
